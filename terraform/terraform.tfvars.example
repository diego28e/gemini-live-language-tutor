# GCP Project ID
project_id = "idiomasocw"

# GCP Compute Region for the API, VPC, Database, and Artifact Registry
region = "us-east1"

# The Docker image generated by building the '/backend' directory.
# Both Cloud Run and Google Compute Engine will run this exact identical image.
# Example: "us-east1-docker.pkg.dev/idiomasocw/ai-tutor/backend:latest"
backend_image = "us-east1-docker.pkg.dev/idiomasocw/ai-tutor/backend:latest"
agent_image   = "us-east1-docker.pkg.dev/idiomasocw/ai-tutor/backend:latest"

# PostgreSQL Password for the `ai-tutor-db`
db_password = "CHANGE_ME_PLEASE"
