# ─── Monorepo Root — Environment Variable Reference ───────────────────────────
# This file documents ALL environment variables used across the project.
# For local development copy the per-package .env.example files (e.g. backend/.env.example).
# For production, variables are injected by Terraform / Cloud Run / Secret Manager.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime mode
NODE_ENV=development   # Set to "production" by Cloud Run automatically via Terraform

# ─── GCP PROJECT ──────────────────────────────────────────────────────────────
# Required by Firebase Admin SDK (Application Default Credentials)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Local:      postgresql://postgres:postgres@localhost:5435/ai-tutor-db
# Production: injected by Terraform as a Cloud SQL Unix socket URL
#             (format: postgresql://postgres:<password>@localhost/ai-tutor-db?host=/cloudsql/<conn_name>)
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/ai-tutor-db

# ─── LIVEKIT ──────────────────────────────────────────────────────────────────
# From your LiveKit Cloud dashboard: https://cloud.livekit.io
# Production: stored in Secret Manager as "livekit-url", "livekit-api-key", "livekit-api-secret"
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ─── GEMINI ───────────────────────────────────────────────────────────────────
# From Google AI Studio: https://aistudio.google.com
# Production: stored in Secret Manager as "gemini-api-key"
GEMINI_API_KEY=your_gemini_api_key

# ─── AZURE COGNITIVE TRANSLATOR ───────────────────────────────────────────────
# Optional — powers the in-lesson word translation feature
# Production: stored in Secret Manager as "azure-translate-key", "azure-translate-endpoint", "azure-translate-region"
AZURE_TRANSLATE_KEY=your_azure_translate_key
AZURE_TRANSLATE_ENDPOINT=https://api.cognitive.microsofttranslator.com
AZURE_TRANSLATE_REGION=eastus

# ─── FRONTEND (Vite build-time) ───────────────────────────────────────────────
# Set in your CI/CD pipeline or Firebase Hosting build step — NOT a backend secret.
# The value comes from `terraform output backend_url` after apply.
VITE_API_URL=https://ai-tutor-backend-<hash>-ue.a.run.app
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-gcp-project-id
