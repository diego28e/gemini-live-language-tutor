# Frontend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION: Set these as Cloud Run environment variables or in your CI/CD.
#             For Firebase Hosting, bake VITE_* vars into the build.
# LOCALLY:    Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

VITE_NODE_ENV=development

# Firebase Client SDK (from Firebase Console → Project Settings → Your apps)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# Backend API URL
# Local:      http://localhost:8080
# Production: Cloud Run URL from `terraform output backend_url`
VITE_API_URL=http://localhost:8080

# LiveKit Server URL (same as backend LIVEKIT_URL but exposed to frontend)
# Local:       ws://localhost:7880  (if running LiveKit locally)
# Production:  wss://your-project.livekit.cloud
VITE_LIVEKIT_URL=ws://localhost:7880
