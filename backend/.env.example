# Backend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION: These are loaded from Google Secret Manager via Cloud Run.
# LOCALLY: Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# GCP Project ID (used by Firebase Admin SDK via Application Default Credentials)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# PostgreSQL connection string
# Local:      postgresql://postgres:postgres@localhost:5435/ai-tutor-db
# Production: managed by Terraform (Cloud SQL Unix socket)
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/ai-tutor-db

# LiveKit Cloud — from your LiveKit dashboard (https://cloud.livekit.io)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Google Gemini API Key — from Google AI Studio (https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key

# Azure AI Translator (optional — for in-lesson word translation feature)
AZURE_TRANSLATE_KEY=your_azure_translate_key
AZURE_TRANSLATE_ENDPOINT=https://api.cognitive.microsofttranslator.com
AZURE_TRANSLATE_REGION=eastus